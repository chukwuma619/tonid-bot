# TON (used by shared + telegram-bot)
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TON_NETWORK=mainnet
TON_EXPLORER_URL=https://tonscan.org

# AI (used by shared for agent)
AI_GATEWAY_API_KEY=
AGENT_MODEL=anthropic/claude-sonnet-4

# Telegram bot. Webhook URL is the bot server, e.g. https://your-domain.com/webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_PIN_APP_URL=

# Redis (used by shared for account/PIN storage)
REDIS_URL=redis://localhost:6379

# Optional: 32-byte hex key to encrypt private keys at rest (64 hex chars). Recommended in production.
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=
